{
  "manifest_version": 3,
  "name": "Search Optimizer",
  "version": "1.1",
  "description": "Clean up your Google search results by hiding unwanted modules and specific sites.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.google.de/*",
    "*://*.google.at/*",
    "*://*.google.ch/*",
    "*://*.google.co.uk/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Search Optimizer Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/*",
        "*://*.google.de/*",
        "*://*.google.at/*",
        "*://*.google.ch/*",
        "*://*.google.co.uk/*"
      ],
      "js": ["content_scripts/link_filter.js"],
      "run_at": "document_idle"
    }
  ]
}

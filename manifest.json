{
  "manifest_version": 3,
  "name": "Search Filter & Site Blocker - Clean Search Results",
  "version": "1.5.5",
  "description": "Block sites from search results, hide ads, sponsored posts, videos & more. Infinite scroll for Google Search results.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.google.de/*",
    "*://*.google.at/*",
    "*://*.google.ch/*",
    "*://*.google.co.uk/*",
    "*://*.google.fr/*",
    "*://*.google.es/*",
    "*://*.google.it/*",
    "*://*.google.nl/*",
    "*://*.google.be/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Search Optimizer Settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/search*",
        "*://*.google.de/search*",
        "*://*.google.at/search*",
        "*://*.google.ch/search*",
        "*://*.google.co.uk/search*",
        "*://*.google.fr/search*",
        "*://*.google.es/search*",
        "*://*.google.it/search*",
        "*://*.google.nl/search*",
        "*://*.google.be/search*"
      ],
      "js": ["content_scripts/link_filter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.google.com/search*",
        "*://*.google.de/search*",
        "*://*.google.at/search*",
        "*://*.google.ch/search*",
        "*://*.google.co.uk/search*",
        "*://*.google.fr/search*",
        "*://*.google.es/search*",
        "*://*.google.it/search*",
        "*://*.google.nl/search*",
        "*://*.google.be/search*"
      ],
      "js": ["content_scripts/operators_panel.js"],
      "run_at": "document_idle"
    }
  ]
}
